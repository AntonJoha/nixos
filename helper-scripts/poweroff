#!/usr/bin/env bash

echo "Shutting down..."

#Docker containers running prevent the computer from shutting down.
echo "Killing containers"
if command -v docker >/dev/null 2>&1; then
  mapfile -t containers < <(docker ps -q 2>/dev/null)
  if ((${#containers[@]})); then
    docker kill "${containers[@]}"
  fi
fi
sleep 1 s

shutdown -h now
